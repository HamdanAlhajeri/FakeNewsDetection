# Tinker API Configuration (Optional - for distributed GPU training)
# Get your API key from: https://tinker.thinkingmachines.ai
# Leave empty to use local training instead
TINKER_API_KEY=your_api_key_here
TINKER_API_URL=https://api.tinker.thinkingmachines.ai
TINKER_PROJECT_ID=your_project_id

# Training Configuration (Optional - defaults in notebooks)
TRAINING_EPOCHS=5
TRAINING_BATCH_SIZE=16
BERT_LEARNING_RATE=2e-5
ROBERTA_LEARNING_RATE=1e-5

# Random Seed (for reproducibility)
RANDOM_SEED=42

# Model Configuration
MODEL_MAX_LENGTH=100
NUM_CLASSES=6
